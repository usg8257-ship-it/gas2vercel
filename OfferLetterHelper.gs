// PIXEL-PERFECT FIELD COORDINATES
// y_pdflib = 841.92 - y_mupdf  (pdf-lib bottom-left origin)
// DATE  → x=453.520  y=733.740  Helvetica Regular 10pt
// NAME  → x=144.860  y=715.120  Helvetica Bold    10pt
// POS   → x=144.860  y=699.880  Helvetica Bold    10pt
// PP NO → x=376.000  y=699.880  Helvetica Bold    10pt

var PSBD_TEMPLATE_B64 = '';

var SIRA_TEMPLATE_B64 = '';

function getOfferLetterTemplate(type) {
  try {
    var b64 = (type === 'SIRA') ? SIRA_TEMPLATE_B64 : PSBD_TEMPLATE_B64;
    logActivity('OfferLetterHelper', 'FETCH_TEMPLATE', type + ' (embedded)', 'SUCCESS');
    return {success: true, data: b64, type: type};
  } catch(e) {
    logActivity('OfferLetterHelper', 'FETCH_ERROR', e.message, 'ERROR');
    return {success: false, error: e.message};
  }
}

function saveTemplateFileIds(psbdId, siraId) {
  try {
    var sh = getOrCreate('AppConfig', ['KEY','VALUE']);
    var vals = sh.getDataRange().getValues();
    var uoa = function(key, val) {
      for (var i = 1; i < vals.length; i++) {
        if (vals[i][0] === key) { sh.getRange(i+1, 2).setValue(val); return; }
      }
      sh.appendRow([key, val]);
    };
    uoa('psbd_template_id', psbdId);
    uoa('sira_template_id', siraId);
    return {success: true};
  } catch(e) { return {success: false, error: e.message}; }
}
